# Mobile (.env) — kopia do .env.local przed pierwszym `expo start`

# Bazowy URL API (dev / prod / customer-specific)
EXPO_PUBLIC_API_URL=https://dev.veloryn.pl

# Reverb (WebSocket / broadcasting)
EXPO_PUBLIC_REVERB_KEY=your_reverb_app_key
EXPO_PUBLIC_REVERB_HOST=reverb.veloryn.pl

# Sentry / error tracking
# Brak DSN = no-op (init pomija). Przy buildach EAS DSN jest wstrzykiwany przez eas.json.
EXPO_PUBLIC_SENTRY_DSN=https://92f91bc671189905ea9a3eeac7cac638@o4508923852488704.ingest.de.sentry.io/4511358594449489

# QR pairing — TTL po stronie mobile (sek). Backend i tak weryfikuje.
EXPO_PUBLIC_QR_PAIRING_TTL_SECONDS=600

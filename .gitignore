# =============================================================================
# Veloryn Mobile — .gitignore
# =============================================================================

# IDE / Editory
.idea/
.vscode/
.claude/*
!.claude/agents/
.claude.json
.codex/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Node
node_modules/
npm-debug.*
yarn-debug.*
yarn-error.*

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native code (regenerated by `expo prebuild`)
ios/
android/

# Env
.env
.env.local
.env.development
.env.production

# Certyfikaty / klucze
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# TypeScript
*.tsbuildinfo

# Logs
*.log
logs/

# Temp
*.tmp
*.temp
*.bak
*.backup

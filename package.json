{
  "name": "veloryn-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Aplikacja mobilna Veloryn (iOS + Android) — Mail, Messenger, QR Auth.",
  "main": "expo-router/entry",
  "repository": {
    "type": "git",
